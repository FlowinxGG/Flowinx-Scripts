local function vincularHerramienta(herramienta)
    if herramienta:IsA("Tool") and herramienta.Name == "Sniper" then
        herramienta.Equipped:Connect(function()
            ArmaEquipada = true
            if Config.Aimbot and CirculoFOV then CirculoFOV.Visible = true end
            iniciarAimbotSilencioso()
        end)

        herramienta.Unequipped:Connect(function()
            ArmaEquipada = false
            if CirculoFOV then CirculoFOV.Visible = false end
            detenerAimbotSilencioso()
        end)
    end
end

local function iniciarCargaDeMochila(personaje)
    local mochila = LocalPlayer:WaitForChild("Backpack", 5)
    if mochila then
        for _, objeto in ipairs(mochila:GetChildren()) do vincularHerramienta(objeto) end
        mochila.ChildAdded:Connect(vincularHerramienta)
    end
    personaje.ChildAdded:Connect(vincularHerramienta)
    ArmaEquipada = false
    detenerAimbotSilencioso()
end

