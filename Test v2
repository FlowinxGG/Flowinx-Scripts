local VELOCIDAD_BALA_SNIPER = 850 
local PING_COMPENSACION = 0.035    

local ConexionAimbot = nil
local ArmaEquipada = false
local esDisparando = false
local historialVelocidades = {}
local DigRemote = nil
local CirculoFOV = nil
