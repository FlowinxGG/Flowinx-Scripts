FlagTab:CreateButton({
    Name = "Robar Bandera Enemiga",
    Callback = function()
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local root = character:WaitForChild("HumanoidRootPart")
        
        local walkSpeed = 30
        local nearLadderDistance = 3 

        local myTeamName = ""
        if LocalPlayer.Team then
            myTeamName = LocalPlayer.Team.Name
        end
        local myTeam = "Blue"
        if string.sub(string.lower(myTeamName), 1, 1) == "r" then
            myTeam = "Red"
        end
        local enemyTeam = "Red"
        if myTeam == "Red" then
            enemyTeam = "Blue"
        end

        local function walkTo(targetCFrame, speed)
            local distance = (root.Position - targetCFrame.Position).Magnitude
            local info = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(root, info, {CFrame = targetCFrame})
            tween:Play()
            tween.Completed:Wait()
        end

        local function findLadderIn(teamName)
            local base = workspace.Map:FindFirstChild(teamName)
            if base and base:FindFirstChild("Hole") then
                return base.Hole:FindFirstChild("Smooth Block Model", true)
            end
            return nil
        end

        local spawnPos = Vector3.new(3.295, -24.45, 1.251)

        local myLadderStart = findLadderIn(myTeam)
        if myLadderStart then
            root.CFrame = myLadderStart:GetPivot() * CFrame.new(0, 0, nearLadderDistance)
            task.wait(0.5)
        end

        local enemyLadder = findLadderIn(enemyTeam)
        local enemyFlag = workspace.Map[enemyTeam].Flag:FindFirstChild("Handle", true)

        if enemyLadder and enemyFlag then
            root.CFrame = enemyLadder:GetPivot() * CFrame.new(0, 0, 5) 
            task.wait(2)
            root.CFrame = enemyLadder:GetPivot() * CFrame.new(0, 7, 0)
            task.wait(0.5)
            walkTo(enemyFlag.CFrame * CFrame.new(0, 2, 0), walkSpeed)
            task.wait(1.5) 

            local myLadder = findLadderIn(myTeam)
            local myFlag = workspace.Map[myTeam].Flag:FindFirstChild("Handle", true)
            
            if myLadder and myFlag then
                root.CFrame = enemyLadder:GetPivot() * CFrame.new(0, 0, 5)
                task.wait(0.5)
                root.CFrame = CFrame.new(spawnPos)

                Rayfield:Notify({
                    Title = "Procesando Captura",
                    Content = "Por favor espera 15 segundos en la base para asegurar el mejor resultado.",
                    Duration = 15,
                    Image = 4483362458
                })
                task.wait(15)

                local nearLadderPoint = myLadder:GetPivot() * CFrame.new(0, 0, nearLadderDistance)
                walkTo(nearLadderPoint, walkSpeed)
                local flagTarget = myFlag.CFrame * CFrame.new(0, 2, 0)
                walkTo(flagTarget, walkSpeed)
            end
        end
    end,
})

