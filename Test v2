local function minarTierraMasivo()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    if not DigRemote then
        pcall(function()
            local events = ReplicatedStorage:FindFirstChild("Events")
            local remote = events and events:FindFirstChild("Remote")
            DigRemote = remote and remote:FindFirstChild("Dig")
        end)
    end
    
    if not DigRemote then return end

    for _, objeto in ipairs(workspace:GetDescendants()) do
        if objeto:IsA("Part") and objeto.Name == "Dirt" and objeto.Parent then
            local idBloque = tonumber(objeto.Parent.Name)
            if idBloque then
                local distancia = (objeto.Position - rootPart.Position).Magnitude
                if distancia < 18 then
                    task.spawn(function()
                        DigRemote:FireServer(idBloque, true)
                    end)
                end
            end
        end
    end
end

local function estaVisible(personajeEnemigo)
    if not personajeEnemigo or not personajeEnemigo:FindFirstChild("HumanoidRootPart") then return false end
    local exito, resultado = pcall(function()
        local puntosOcultos = Camera:GetPartsObscuringTarget(
            {personajeEnemigo.HumanoidRootPart.Position}, 
            {LocalPlayer.Character, personajeEnemigo}
        )
        return #puntosOcultos == 0
    end)
    return exito and resultado or false
end

local function obtenerEnemigoMasCercano()
    local mejorObjetivo = nil
    local distanciaMaxima = math.huge
    local centroPantalla = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, jugador in ipairs(Players:GetPlayers()) do
        if jugador ~= LocalPlayer and jugador.Team ~= LocalPlayer.Team then
            local personaje = jugador.Character
            if personaje and personaje:FindFirstChild("Humanoid") and personaje.Humanoid.Health > 0 and personaje:FindFirstChild("HumanoidRootPart") then
                if estaVisible(personaje) then
                    local posicionPantalla, visibleEnPantalla = Camera:WorldToViewportPoint(personaje.HumanoidRootPart.Position)
                    if visibleEnPantalla then
                        local distanciaAlCentro = (Vector2.new(posicionPantalla.X, posicionPantalla.Y) - centroPantalla).Magnitude
                        if distanciaAlCentro <= RADIO_FOV then
                            local miTorso = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if miTorso then
                                local distanciaStuds = (personaje.HumanoidRootPart.Position - miTorso.Position).Magnitude
                                if distanciaStuds < distanciaMaxima then
                                    distanciaMaxima = distanciaStuds
                                    mejorObjetivo = jugador
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return mejorObjetivo, distanciaMaxima
end

local function calcularPrediccionEstrategica(jugadorEnemigo, parteNombre, distancia)
    local personaje = jugadorEnemigo.Character
    local parte = personaje:FindFirstChild(parteNombre) or personaje:FindFirstChild("HumanoidRootPart")
    local rootEnemigo = personaje:FindFirstChild("HumanoidRootPart")
    local rootMio = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not parte or not rootEnemigo or not rootMio then 
        if parte then 
            return parte.Position 
        else 
            return nil 
        end 
    end
    
    local velEnemigo = rootEnemigo.AssemblyLinearVelocity
    local velMia = rootMio.AssemblyLinearVelocity
    local velocidadRelativa = velEnemigo - velMia
    
    local tiempoDeVuelo = (distancia / VELOCIDAD_BALA_SNIPER) + PING_COMPENSACION
    
    local idJugador = jugadorEnemigo.UserId
    local ultimaVelocidad = historialVelocidades[idJugador] or velEnemigo
    historialVelocidades[idJugador] = velEnemigo
    
    local haciendoMovimientoInsano = (ultimaVelocidad.X > 1 and velEnemigo.X < -1) or (ultimaVelocidad.X < -1 and velEnemigo.X > 1)
    
    if haciendoMovimientoInsano or velocidadRelativa.Magnitude < 3 then
        return personaje.HumanoidRootPart.Position
    end
    
    if math.abs(velEnemigo.Y) > 1.5 then
        return rootEnemigo.Position + (velocidadRelativa * tiempoDeVuelo) - Vector3.new(0, 0.8, 0)
    end
    
    return parte.Position + (velocidadRelativa * (tiempoDeVuelo * 1.15))
end

local function forzarDisparoGatillo(objetivo, distancia)
    if esDisparando or not objetivo.Character or not Config.Aimbot then return end
    esDisparando = true
    
    local parteBase = "UpperTorso"
    if math.random(1, 10) <= 2 then parteBase = "Head" end
    
    local posicionFuturaDisparo = calcularPrediccionEstrategica(objetivo, parteBase, distancia)
    
    if posicionFuturaDisparo then
        pcall(function()
            local repStorage = game:GetService("ReplicatedStorage")
            local events = repStorage:FindFirstChild("Events")
            local remote = events and events:FindFirstChild("Remote")
            local shotTarget = remote and remote:FindFirstChild("ShotTarget")
            
            if shotTarget then
                shotTarget:FireServer(posicionFuturaDisparo, "Sniper")
            end
        end)
    end
    
    task.wait(0.12)
    esDisparando = false
end

local function iniciarAimbotSilencioso()
    if ConexionAimbot then return end
    ConexionAimbot = RunService.RenderStepped:Connect(function()
        if ArmaEquipada and Config.Aimbot then
            local objetivo, distancia = obtenerEnemigoMasCercano()
            if objetivo and objetivo.Character then
                task.spawn(function()
                    forzarDisparoGatillo(objetivo, distancia)
                end)
            end
        end
    end)
end

local function detenerAimbotSilencioso()
    if ConexionAimbot then
        ConexionAimbot:Disconnect()
        ConexionAimbot = nil
    end
end

