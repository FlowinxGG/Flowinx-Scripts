local function crearESP(jugador)
    if jugador == LocalPlayer then return end
    
    local function aplicarUI(personaje)
        if not personaje then return end
        local torso = personaje:WaitForChild("HumanoidRootPart", 5)
        if not torso then return end

        if torso:FindFirstChild("ESP_UI") then torso.ESP_UI:Destroy() end
        if personaje:FindFirstChild("ESP_Cuerpo") then personaje.ESP_Cuerpo:Destroy() end

        local sgui = Instance.new("BillboardGui")
        sgui.Name = "ESP_UI"
        sgui.AlwaysOnTop = true
        sgui.Size = UDim2.new(0, 200, 0, 60)
        sgui.StudsOffset = Vector3.new(0, 3, 0)
        sgui.Adornee = torso
        sgui.Parent = torso

        local texto = Instance.new("TextLabel", sgui)
        texto.Size = UDim2.new(1, 0, 1, 0)
        texto.BackgroundTransparency = 1 
        texto.TextStrokeTransparency = 0  
        texto.Font = Enum.Font.SourceSansBold
        texto.TextSize = 11

        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Cuerpo"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0.2
        highlight.Parent = personaje

        local bucleESP
        bucleESP = RunService.RenderStepped:Connect(function()
            if not jugador or not jugador.Parent or not personaje or not personaje.Parent or not personaje:FindFirstChild("Humanoid") or personaje.Humanoid.Health <= 0 then
                sgui:Destroy()
                highlight:Destroy()
                bucleESP:Disconnect()
                return
            end

            if jugador.Team == LocalPlayer.Team then
                sgui.Enabled = false
                highlight.Enabled = false
                return
            end

            highlight.Enabled = Config.ESP

            local miTorso = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if miTorso then
                local distancia = math.floor((torso.Position - miTorso.Position).Magnitude)
                local cubierto = not estaVisible(personaje)
                
                local vidaActual = math.floor(personaje.Humanoid.Health)
                local vidaMaxima = math.floor(personaje.Humanoid.MaxHealth)
                
                local armaEquipadaEnemigo = "Ninguna"
                for _, herramienta in ipairs(personaje:GetChildren()) do
                    if herramienta:IsA("Tool") then
                        armaEquipadaEnemigo = herramienta.Name
                        break
                    end
                end

                local lineaIdentificacion = ""
                if Config.ESP then
                    lineaIdentificacion = jugador.Name
                end
                
                local lineaDatosHUD = ""
                if Config.TagHUD then
                    lineaDatosHUD = "\n[Arma: " .. armaEquipadaEnemigo .. "] - [HP: " .. vidaActual .. "/" .. vidaMaxima .. "]"
                end
                
                local lineaDistancia = ""
                if Config.ESP then
                    if cubierto then
                        lineaDistancia = "\n[Oculto] " .. distancia .. "m"
                    else
                        lineaDistancia = "\n[Visto] " .. distancia .. "m"
                    end
                end

                if not Config.ESP and not Config.TagHUD then
                    sgui.Enabled = false
                else
                    sgui.Enabled = true
                    texto.Text = lineaIdentificacion .. lineaDatosHUD .. lineaDistancia
                end

                if cubierto then
                    texto.TextColor3 = Color3.fromRGB(255, 130, 0)
                    highlight.FillColor = Color3.fromRGB(255, 130, 0)
                else
                    if distancia <= DISTANCIA_CORTA then
                        texto.TextColor3 = Color3.fromRGB(255, 0, 0)
                        highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    else
                        texto.TextColor3 = Color3.fromRGB(0, 255, 100)
                        highlight.FillColor = Color3.fromRGB(0, 255, 0)
                    end
                end
            end
        end)
    end

    if jugador.Character then aplicarUI(jugador.Character) end
    jugador.CharacterAdded:Connect(aplicarUI)
end-- ==========================================
